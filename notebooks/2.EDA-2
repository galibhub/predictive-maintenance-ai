97332975212\n        ],\n        \"semantic_type\": \"\",\n        \"description\": \"\"\n      }\n    },\n    {\n      \"column\": \"Rotational speed [rpm]\",\n      \"properties\": {\n        \"dtype\": \"number\",\n        \"std\": 0.5943047792102829,\n        \"min\": -0.8750270862996037,\n        \"max\": 1.0,\n        \"num_unique_values\": 6,\n        \"samples\": [\n          0.022670458795535774,\n          0.019276713901797683,\n          -0.044187559734375326\n        ],\n        \"semantic_type\": \"\",\n        \"description\": \"\"\n      }\n    },\n    {\n      \"column\": \"Torque [Nm]\",\n      \"properties\": {\n        \"dtype\": \"number\",\n        \"std\": 0.5981807717766756,\n        \"min\": -0.8750270862996037,\n        \"max\": 1.0,\n        \"num_unique_values\": 6,\n        \"samples\": [\n          -0.013777823050932982,\n          -0.01406061311689268,\n          0.1913207750594941\n        ],\n        \"semantic_type\": \"\",\n        \"description\": \"\"\n      }\n    },\n    {\n      \"column\": \"Tool wear [min]\",\n      \"properties\": {\n        \"dtype\": \"number\",\n        \"std\": 0.3996790332714364,\n        \"min\": -0.003092781440768214,\n        \"max\": 1.0,\n        \"num_unique_values\": 6,\n        \"samples\": [\n          0.013852827663160141,\n          0.013487517120005912,\n          0.1054482189195948\n        ],\n        \"semantic_type\": \"\",\n        \"description\": \"\"\n      }\n    },\n    {\n      \"column\": \"Machine failure\",\n      \"properties\": {\n        \"dtype\": \"number\",\n        \"std\": 0.38586826367267874,\n        \"min\": -0.044187559734375326,\n        \"max\": 1.0,\n        \"num_unique_values\": 6,\n        \"samples\": [\n          0.08255568978322685,\n          0.03594597332975212,\n          1.0\n        ],\n        \"semantic_type\": \"\",\n        \"description\": \"\"\n      }\n    }\n  ]\n}"}},"metadata":{},"execution_count":31}]},{"cell_type":"code","source":["plt.figure(figsize=(8,6))\n","\n","sns.heatmap(\n","    corr_df.corr(),\n","    annot=True,\n","    cmap=\"coolwarm\",\n","    fmt=\".2f\"\n",")\n","\n","plt.title(\n","    \"Correlation Heatmap\"\n",")\n","\n","plt.show()"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":699},"id":"byo5rtYxyTDZ","executionInfo":{"status":"ok","timestamp":1781686629482,"user_tz":-360,"elapsed":350,"user":{"displayName":"Ibrahim Ahmed Galib","userId":"13250140790318588929"}},"outputId":"d51dd116-7621-4c48-a666-b9140f9c02c7"},"execution_count":32,"outputs":[{"output_type":"display_data","data":{"text/plain":["<Figure size 800x600 with 2 Axes>"],"image/png":"\n"},"metadata":{}}]},{"cell_type":"markdown","source":["# Notebook 02 Conclusion\n","\n","The exploratory data analysis revealed several important patterns related to machine failure.\n","\n","Torque and Tool Wear showed the strongest relationship with machine failure. Failed machines generally operate under higher torque and have significantly higher tool wear.\n","\n","Rotational Speed demonstrated an inverse relationship with failure, indicating that machines operating at lower RPM under load are more likely to fail.\n","\n","Process Temperature appears to be more informative than Air Temperature, suggesting that internal machine heat contributes more to failure risk than environmental temperature.\n","\n","Machine Type also affects reliability, with Low-quality (L) machines showing the highest failure rate and High-quality (H) machines showing the lowest.\n","\n","These findings provide strong motivation for creating new engineered features in the next notebook, such as temperature gap, power, wear rate, and stress indicators."],"metadata":{"id":"pbj39GP410wJ"}},{"cell_type":"code","source":[],"metadata":{"id":"eqGYzHfM11yp"},"execution_count":null,"outputs":[]}]}